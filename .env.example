# Qdrant Cloud Configuration (Required)
QDRANT_URL=https://your-cluster-url.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
COLLECTION_NAME=rag_documents

# Ollama Configuration (Local AI Models)
# Make sure Ollama is running: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=qwen2.5vl:3b
# Force vision model CPU execution if needed (0 = CPU, leave blank or omit to default to GPU with auto CPU retry fallback)
OLLAMA_VISION_NUM_GPU=
OLLAMA_VISION_NUM_GPU=0